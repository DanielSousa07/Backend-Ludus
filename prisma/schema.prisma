generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum RentalStatus {
  PENDING
  ACTIVE
  RETURNED
  CANCELED
}


enum GameTier {
  LATAO
  BRONZE
  PRATA
  OURO
  DIAMANTE
}


enum ClientCategory {
  STARTER
  FAMILY
  EXPERT
  ULTRAGAMER
}

enum NotificationType {
  RENTAL_CREATED
  RENTAL_DUE_24H
  RENTAL_DUE_TODAY
  RENTAL_OVERDUE
  RENTAL_RETURN_CONFIRMED
  RATING_SAVED
  FAVORITE_ADDED
  FAVORITE_REMOVED
  EMAIL_VERIFIED
  PHONE_VERIFIED
  VERIFY_REQUIRED
  POINTS_EARNED
  LEVEL_UP
  SYSTEM_ANNOUNCEMENT
  GAME_BACK_AVAILABLE
}

model User {
  id    String  @id @default(uuid())
  name  String
  email String  @unique
  phone String? @unique

  emailVerified         Boolean   @default(false)
  emailVerificationCode String?
  emailCodeExpiresAt    DateTime?
  lastEmailSentAt       DateTime?

  phoneVerified    Boolean   @default(false)
  verificationCode String?
  codeExpiresAt    DateTime?
  lastCodeSentAt   DateTime?

  avatar  String?
  picture String?

  points Int @default(0)
  level  Int @default(1)

  senhaHash    String?
  googleSub    String?      @unique
  authProvider AuthProvider @default(LOCAL)

  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?

  role String @default("USER")


  clientCategory    ClientCategory @default(STARTER)
  totalRentalsCount Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games         Game[]
  rentals       Rental[]
  ratings       GameRating[]
  pointsLogs    UserPointsLog[]
  favorites     Favorite[]
  pushTokens    PushToken[]
  notifications Notification[]

  gameAvailabilityWatches GameAvailabilityWatch[]
}

model Game {
  id                  String  @id @default(uuid())
  ludopediaId         Int?
  title               String
  description         String?
  price               Float
  available           Boolean @default(true)
  cover               String?
  allowOriginalRental Boolean @default(true)

  rating       Float   @default(0)
  ratingsCount Int?
  howToPlayUrl String? @db.Text

  isActive  Boolean @default(true)
  isVisible Boolean @default(true)


  tier GameTier @default(BRONZE)

  minPlayers Int @default(1)
  maxPlayers Int?
  minAge     Int @default(0)
  minTime    Int @default(0)
  maxTime    Int?

  userId String
  owner  User   @relation(fields: [userId], references: [id])

  components GameComponent[]
  rentals    Rental[]
  ratings    GameRating[]
  copies     GameCopy[]
  favorites  Favorite[]

  gameAvailabilityWatches GameAvailabilityWatch[]

  @@index([title])
  @@index([ludopediaId])
}

model GameComponent {
  id       String @id @default(uuid())
  gameId   String
  name     String
  quantity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, name])
  @@index([gameId])
}

model Favorite {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model UserPointsLog {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GameCopy {
  id        String  @id @default(uuid())
  number    Int
  code      String?
  condition String?
  available Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  rentals Rental[]

  @@unique([gameId, number])
  @@index([gameId])
}

model GameRating {
  id        String   @id @default(uuid())
  value     Int
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId])
}

model GameAvailabilityWatch {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId])
}

model Rental {
  id        String       @id @default(uuid())
  startDate DateTime     @default(now())
  endDate   DateTime
  status    RentalStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gameId String?
  game   Game?  @relation(fields: [gameId], references: [id], onDelete: SetNull)

  copyId String?
  copy   GameCopy? @relation(fields: [copyId], references: [id], onDelete: SetNull)

  gameTitleSnapshot  String
  gameCoverSnapshot  String?
  copyCodeSnapshot   String?
  copyNumberSnapshot Int?

  @@index([gameId])
  @@index([copyId])
  @@index([userId])
  @@index([status])
}

model PushToken {
  id            String   @id @default(cuid())
  userId        String
  expoPushToken String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  dedupeKey String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([dedupeKey])
}

model PendingRegistration {
  id String @id @default(uuid())

  name      String
  email     String  @unique
  phone     String? @unique
  senhaHash String

  acceptedTerms   Boolean @default(false)
  acceptedPrivacy Boolean @default(false)

  emailVerificationCode String?
  emailCodeExpiresAt    DateTime?
  lastEmailSentAt       DateTime?

  phoneVerificationCode String?
  phoneCodeExpiresAt    DateTime?
  lastPhoneSentAt       DateTime?

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
